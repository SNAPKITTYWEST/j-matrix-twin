{
  "name": "j-matrix-twin-playground",
  "version": "1.0.0",
  "description": "Interactive playground for J Matrix Twin - SUBLEQ Attention Engine",
  "main": "server/server.js",
  "scripts": {
    "start": "node server/server.js",
    "dev": "node server/server.js",
    "asbuild:untouched": "asc assembly/index.ts --target release --outFile public/j-matrix.wasm --textFile public/j-matrix.wat",
    "asbuild:optimized": "asc assembly/index.ts --target release --optimize --outFile public/j-matrix.wasm",
    "asbuild": "npm run asbuild:optimized",
    "build": "npm run asbuild",
    "deploy": "npm run build && gh-pages -d public"
  },
  "keywords": [
    "j-language",
    "subleq",
    "attention-mechanism",
    "tacit-programming",
    "goldilocks-field",
    "quantum-computing",
    "array-programming"
  ],
  "author": "Jessica (SNAPKITTYWEST) <jessicalw34@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "assemblyscript": "^0.27.0",
    "gh-pages": "^6.1.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jessicalw34/j-matrix-twin.git"
  },
  "bugs": {
    "url": "https://github.com/jessicalw34/j-matrix-twin/issues"
  },
  "homepage": "https://jessicalw34.github.io/j-matrix-twin"
}